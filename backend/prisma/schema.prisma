generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  NEW
  PROCESSING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELED
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id               String         @id @default(cuid())
  name             String
  slug             String         @unique
  sku              String         @unique
  shortDescription String
  description      String
  price            Decimal        @db.Decimal(12, 2)
  material         String
  color            String
  dimensions       String
  specifications   Json
  stock            Int
  featured         Boolean        @default(false)
  bestSeller       Boolean        @default(false)
  isNew            Boolean        @default(true)
  categoryId       String
  category         Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  embedding        ProductEmbedding?
  images           ProductImage[]
  orderItems       OrderItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([categoryId])
  @@index([featured, bestSeller, isNew])
  @@index([createdAt])
}

model ProductEmbedding {
  productId   String                 @id
  product     Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceText  String
  embedding   Unsupported("vector")?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([updatedAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  altText   String?
  sortOrder Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Order {
  id           String       @id @default(cuid())
  code         String       @unique
  customerName String
  phone        String
  email        String
  address      String
  note         String?
  status       OrderStatus  @default(NEW)
  subtotal     Decimal      @db.Decimal(12, 2)
  shippingFee  Decimal      @db.Decimal(12, 2)
  total        Decimal      @db.Decimal(12, 2)
  items        OrderItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                  String   @id @default(cuid())
  quantity            Int
  unitPrice           Decimal  @db.Decimal(12, 2)
  productNameSnapshot String
  productSlugSnapshot String
  imageSnapshot       String?
  orderId             String
  productId           String?
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String
  authorName  String
  isPublished Boolean   @default(true)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([publishedAt])
  @@index([createdAt])
}

model ContactInfo {
  id          String   @id @default(cuid())
  phone       String
  email       String
  address     String
  facebook    String?
  zalo        String?
  instagram   String?
  mapEmbedUrl String?
  workingHours String
  introText   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id         String   @id @default(cuid())
  name       String
  phone      String
  email      String
  subject    String
  message    String
  isHandled  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isHandled])
  @@index([createdAt])
}
